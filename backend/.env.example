APP_ENV=development
SERVER_PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/small_shop

# OAuth Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# JWT / CSRF (>= 32 chars)
JWT_SECRET=replace-with-strong-random-secret-at-least-32-chars
JWT_EXPIRATION_HOURS=24
CSRF_COOKIE_KEY=replace-with-strong-random-secret-at-least-32-chars

# Frontend URL (for CORS + OAuth redirect)
FRONTEND_URL=http://localhost:8080

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
CONTACT_FROM_NAME=Small Shop
CONTACT_FROM_EMAIL=no-reply@example.com
CONTACT_ADMIN_EMAIL=admin@example.com
REPLY_LOGO_URL=

# Security / anti-bot
CLOUDFLARE_SECRET_KEY=your-turnstile-secret

# Initial admin seed (required)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-admin-password

# Optional media
# UPLOAD_BACKEND=cloudinary
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Optional deploy/runtime controls
# AUTO_RUN_MIGRATIONS=true
